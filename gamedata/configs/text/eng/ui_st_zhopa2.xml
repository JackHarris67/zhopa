	<string id="ui_mcm_zhopa2_group_systems"><text>Systems</text></string>
	<string id="ui_mcm_zhopa2_group_story"><text>Story systems</text></string>
	<string id="ui_mcm_zhopa2_group_roam"><text>Roam tasks</text></string>
