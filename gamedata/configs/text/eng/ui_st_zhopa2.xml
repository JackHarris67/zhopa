	<string id="ui_mcm_zhopa2_group_mutants_movement"><text>Movement</text></string>
	<string id="ui_mcm_zhopa2_group_mutants_timing"><text>Timing</text></string>
	<string id="ui_mcm_zhopa2_enabled"><text>Enable ZHOPA ALIFE 2</text></string>
	<string id="ui_mcm_zhopa2_enabled_desc"><text>Master switch for all ZHOPA ALIFE 2 simulation systems.</text></string>
	<string id="ui_mcm_zhopa2_stalker_movement_enabled"><text>Stalker movement</text></string>
	<string id="ui_mcm_zhopa2_stalker_movement_enabled_desc"><text>Allows managed stalker squads to receive ZHOPA tasks.</text></string>
	<string id="ui_mcm_zhopa2_mutant_movement_enabled"><text>Mutant movement</text></string>
	<string id="ui_mcm_zhopa2_mutant_movement_enabled_desc"><text>Allows managed mutant squads to receive ZHOPA tasks.</text></string>
	<string id="ui_mcm_zhopa2_debug_hud_enabled"><text>Debug HUD</text></string>
	<string id="ui_mcm_zhopa2_debug_hud_enabled_desc"><text>Shows squad state markers and enables extra diagnostic console output.</text></string>
	<string id="ui_mcm_zhopa2_service_filler_enabled"><text>Service fillers</text></string>
	<string id="ui_mcm_zhopa2_service_filler_enabled_desc"><text>Lets ZHOPA fill marked smart terrains with missing trader, technician, medic, barman, or guide squads.</text></string>
	<string id="ui_mcm_zhopa2_loot_enabled"><text>Online looting</text></string>
	<string id="ui_mcm_zhopa2_loot_enabled_desc"><text>Enables the managed online looting layer for visible NPC squads.</text></string>
	<string id="ui_mcm_zhopa2_loot_offline_enabled"><text>Offline looting</text></string>
	<string id="ui_mcm_zhopa2_loot_offline_enabled_desc"><text>Enables offline loot accounting for simulated squads.</text></string>
	<string id="ui_mcm_zhopa2_loot_offline_real_enabled"><text>Real offline loot</text></string>
	<string id="ui_mcm_zhopa2_loot_offline_real_enabled_desc"><text>Moves real server-side inventory items during offline looting when possible.</text></string>
	<string id="ui_mcm_zhopa2_artefact_offline_enabled"><text>Offline artefacts</text></string>
	<string id="ui_mcm_zhopa2_artefact_offline_enabled_desc"><text>Allows offline squads to use virtual artefact targets when no real artefact is available on their route.</text></string>
	<string id="ui_mcm_zhopa2_trade_enabled"><text>Economy and trade</text></string>
	<string id="ui_mcm_zhopa2_trade_enabled_desc"><text>Enables managed NPC trade, trade route tasks, and offline trade accounting.</text></string>
	<string id="ui_mcm_zhopa2_story_psy_watchdog_enabled"><text>Brain Scorcher watchdog</text></string>
	<string id="ui_mcm_zhopa2_story_psy_watchdog_enabled_desc"><text>Converts non-immune stalker squads on active psi levels into zombified squads.</text></string>
	<string id="ui_mcm_zhopa2_story_north_migration_enabled"><text>North migration</text></string>
	<string id="ui_mcm_zhopa2_story_north_migration_enabled_desc"><text>After Brain Scorcher shutdown, routes selected stalker squads toward northern levels.</text></string>
	<string id="ui_mcm_zhopa2_story_north_migration_percent"><text>North migration percent</text></string>
	<string id="ui_mcm_zhopa2_story_north_migration_percent_desc"><text>Percent of eligible stalker squads selected when the story event fires.</text></string>
	<string id="ui_mcm_zhopa2_explore_enabled"><text>Explore tasks</text></string>
	<string id="ui_mcm_zhopa2_explore_enabled_desc"><text>Allows stalker squads to choose exploration targets.</text></string>
	<string id="ui_mcm_zhopa2_populate_enabled"><text>Populate tasks</text></string>
	<string id="ui_mcm_zhopa2_populate_enabled_desc"><text>Allows stalker squads to move into valid smart terrains that need occupants.</text></string>
	<string id="ui_mcm_zhopa2_base_camping_enabled"><text>Base camping tasks</text></string>
	<string id="ui_mcm_zhopa2_base_camping_enabled_desc"><text>Allows stalker squads to occupy base camp slots on suitable smart terrains.</text></string>
	<string id="ui_mcm_zhopa2_patrol_enabled"><text>Patrol tasks</text></string>
	<string id="ui_mcm_zhopa2_patrol_enabled_desc"><text>Allows stalker squads to patrol between valid smart terrain targets.</text></string>
	<string id="ui_mcm_zhopa2_night_rest_enabled"><text>Night rest tasks</text></string>
	<string id="ui_mcm_zhopa2_night_rest_enabled_desc"><text>Allows stalker squads to pause movement during night rest windows.</text></string>
	<string id="ui_mcm_zhopa2_stalker_hunt_enabled"><text>Stalker hunt tasks</text></string>
	<string id="ui_mcm_zhopa2_stalker_hunt_enabled_desc"><text>Allows stalker squads to hunt hostile squads and valid enemies.</text></string>
	<string id="ui_mcm_zhopa2_artefact_enabled"><text>Artefact tasks</text></string>
	<string id="ui_mcm_zhopa2_artefact_enabled_desc"><text>Allows stalker squads to search for and collect artefacts.</text></string>
	<string id="ui_mcm_zhopa2_stalker_explore_weight"><text>Explore weight</text></string>
	<string id="ui_mcm_zhopa2_stalker_explore_weight_desc"><text>Relative chance for stalker squads to pick exploration.</text></string>
	<string id="ui_mcm_zhopa2_stalker_populate_weight"><text>Populate weight</text></string>
	<string id="ui_mcm_zhopa2_stalker_populate_weight_desc"><text>Relative chance for stalker squads to pick populate tasks.</text></string>
	<string id="ui_mcm_zhopa2_stalker_patrol_weight"><text>Patrol weight</text></string>
	<string id="ui_mcm_zhopa2_stalker_patrol_weight_desc"><text>Relative chance for stalker squads to pick patrol tasks.</text></string>
	<string id="ui_mcm_zhopa2_stalker_hunt_weight"><text>Hunt weight</text></string>
	<string id="ui_mcm_zhopa2_stalker_hunt_weight_desc"><text>Relative chance for stalker squads to pick hunt tasks.</text></string>
	<string id="ui_mcm_zhopa2_stalker_artefact_weight"><text>Artefact weight</text></string>
	<string id="ui_mcm_zhopa2_stalker_artefact_weight_desc"><text>Relative chance for stalker squads to pick artefact tasks.</text></string>
	<string id="ui_mcm_zhopa2_stalker_trade_weight"><text>Trade weight</text></string>
	<string id="ui_mcm_zhopa2_stalker_trade_weight_desc"><text>Base chance for stalker squads to pick a dedicated trade route. Inventory value adds a bonus.</text></string>
	<string id="ui_mcm_zhopa2_rest_duration_game_hours"><text>Rest duration</text></string>
	<string id="ui_mcm_zhopa2_rest_duration_game_hours_desc"><text>Game hours a stalker squad spends in regular rest.</text></string>
	<string id="ui_mcm_zhopa2_patrol_duration_game_hours"><text>Patrol duration</text></string>
	<string id="ui_mcm_zhopa2_patrol_duration_game_hours_desc"><text>Game hours a stalker squad spends on patrol before selecting another task.</text></string>
	<string id="ui_mcm_zhopa2_rest_fallback_stay_min_sec"><text>Fallback stay minimum</text></string>
	<string id="ui_mcm_zhopa2_rest_fallback_stay_min_sec_desc"><text>Minimum real-time seconds for fallback rest when no valid task is available.</text></string>
	<string id="ui_mcm_zhopa2_rest_fallback_stay_max_sec"><text>Fallback stay maximum</text></string>
	<string id="ui_mcm_zhopa2_rest_fallback_stay_max_sec_desc"><text>Maximum real-time seconds for fallback rest when no valid task is available.</text></string>
	<string id="ui_mcm_zhopa2_target_sync_enabled"><text>Target sync</text></string>
	<string id="ui_mcm_zhopa2_target_sync_enabled_desc"><text>Keeps squad task target fields synchronized with the active scripted task.</text></string>
	<string id="ui_mcm_zhopa2_online_intent_enforce_enabled"><text>Online intent enforce</text></string>
	<string id="ui_mcm_zhopa2_online_intent_enforce_enabled_desc"><text>Pushes online squads back to their current ZHOPA task when vanilla smart logic tries to take over.</text></string>
	<string id="ui_mcm_zhopa2_revenge_enabled"><text>Revenge tasks</text></string>
	<string id="ui_mcm_zhopa2_revenge_enabled_desc"><text>Allows squads to retaliate against squads that recently attacked them.</text></string>
	<string id="ui_mcm_zhopa2_revenge_actor_enabled"><text>Actor revenge</text></string>
	<string id="ui_mcm_zhopa2_revenge_actor_enabled_desc"><text>Allows squads to retaliate against the actor when the actor becomes their revenge target.</text></string>
	<string id="ui_mcm_zhopa2_revenge_actor_chance"><text>Actor revenge chance</text></string>
	<string id="ui_mcm_zhopa2_revenge_actor_chance_desc"><text>Percent chance that a valid revenge event against the actor becomes an active revenge task.</text></string>
	<string id="ui_mcm_zhopa2_hunt_offline_combat_enabled"><text>Offline hunt combat</text></string>
	<string id="ui_mcm_zhopa2_hunt_offline_combat_enabled_desc"><text>Allows hunt tasks to resolve combat while both squads are offline.</text></string>
	<string id="ui_mcm_zhopa2_hunt_offline_combat_interval_sec"><text>Offline combat interval</text></string>
	<string id="ui_mcm_zhopa2_hunt_offline_combat_interval_sec_desc"><text>Seconds between offline combat checks for hunt tasks.</text></string>
	<string id="ui_mcm_zhopa2_hunt_offline_combat_distance"><text>Offline combat distance</text></string>
	<string id="ui_mcm_zhopa2_hunt_offline_combat_distance_desc"><text>Distance in meters at which offline hunt combat can resolve.</text></string>
	<string id="ui_mcm_zhopa2_mutant_explore_enabled"><text>Mutant explore</text></string>
	<string id="ui_mcm_zhopa2_mutant_explore_enabled_desc"><text>Allows mutant squads to roam toward valid exploration targets.</text></string>
	<string id="ui_mcm_zhopa2_mutant_hunt_enabled"><text>Mutant hunt</text></string>
	<string id="ui_mcm_zhopa2_mutant_hunt_enabled_desc"><text>Allows mutant squads to hunt hostile stalker squads.</text></string>
	<string id="ui_mcm_zhopa2_mutant_patrol_enabled"><text>Mutant patrol</text></string>
	<string id="ui_mcm_zhopa2_mutant_patrol_enabled_desc"><text>Allows mutant squads to patrol between valid smart terrain targets.</text></string>
	<string id="ui_mcm_zhopa2_mutant_hunt_weight"><text>Mutant hunt weight</text></string>
	<string id="ui_mcm_zhopa2_mutant_hunt_weight_desc"><text>Relative chance for mutant squads to pick hunt tasks.</text></string>
	<string id="ui_mcm_zhopa2_mutant_patrol_weight"><text>Mutant patrol weight</text></string>
	<string id="ui_mcm_zhopa2_mutant_patrol_weight_desc"><text>Relative chance for mutant squads to pick patrol tasks.</text></string>
	<string id="ui_mcm_zhopa2_mutant_explore_weight"><text>Mutant explore weight</text></string>
	<string id="ui_mcm_zhopa2_mutant_explore_weight_desc"><text>Relative chance for mutant squads to pick exploration.</text></string>
	<string id="ui_mcm_zhopa2_mutant_rest_duration_game_hours"><text>Mutant rest duration</text></string>
	<string id="ui_mcm_zhopa2_mutant_rest_duration_game_hours_desc"><text>Game hours a mutant squad spends in rest.</text></string>
	<string id="ui_mcm_zhopa2_mutant_patrol_duration_game_hours"><text>Mutant patrol duration</text></string>
	<string id="ui_mcm_zhopa2_mutant_patrol_duration_game_hours_desc"><text>Game hours a mutant squad spends on patrol before selecting another task.</text></string>
</string_table>
